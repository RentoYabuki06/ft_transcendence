# Vite開発サーバーのホスト設定
# コンテナ外からもアクセス可能に
# 'true' を指定すると全てのネットワークインターフェースでリッスン
# それ以外の値（例: '0.0.0.0'）を指定することも可能
VITE_HOST=true

# Vite開発サーバーのポート番号
VITE_PORT=5173

# APIプロキシのパス（先頭のスラッシュを含む）
VITE_API_PROXY_PATH=/api

# バックエンドAPIのターゲットURL
# Docker Composeを使用している場合は、サービス名を使用（例: backend）
VITE_API_TARGET=http://backend:3000