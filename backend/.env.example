DATABASE_URL="file:./data/dev.db"
# JWT_SECRET は 32 文字以上の十分ランダムな文字列を設定してください (必須)。
# 例: `openssl rand -base64 48`
JWT_SECRET="PLEASE-REPLACE-WITH-A-LONG-RANDOM-SECRET-AT-LEAST-32-CHARS"
PORT=3000
HOST=0.0.0.0
# 42 OAuth credentials (get from intra.42.fr)
INTRA42_CLIENT_ID=""
INTRA42_CLIENT_SECRET=""
INTRA42_REDIRECT_URI="https://localhost:8443/api/auth/42/callback"
FRONTEND_URL="https://localhost:8443"
# SMTP (optional — 未設定の場合 OTP はサーバーログに出力されます)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@ft-transcendence.local"
