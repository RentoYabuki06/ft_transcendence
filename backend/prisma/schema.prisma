// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// Enums (列挙型)
// ------------------------------------------------------

/// 認証プロバイダーの種類
enum AuthProvider {
  intra42  // 42 Intra OAuth
}

// ------------------------------------------------------
// Models (テーブル定義)
// ------------------------------------------------------

/// ステータスマスターテーブル
/// 各エンティティのステータスを一元管理します
model Statuses {
  id              Int      @id @default(autoincrement())
  
  category        String   /// どのモデル用か ('user', 'game', 'tournament', 'waitroom', 'gametype')
  name            String   /// ステータス名 ('active', 'pending', 'ongoing', etc.)
  description     String?  /// ステータスの説明
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  
  /// 同じカテゴリ内で同じ名前のステータスが重複しないように
  @@unique([category, name])
}

/// ユーザー情報を管理するテーブル
/// 認証情報は Accounts テーブルに分離し、プロフィール情報のみを管理します
model Users {
  id                 Int          @id @default(autoincrement())
  
  email              String       @unique /// メールアドレス（システム内で一意）
  name               String       /// 氏名（42のintra名など）
  nickname           String       /// 表示名
  pictureURL         String?      /// アバター画像のURL
  statusId           Int          /// アカウント状態（Statusesテーブルへの参照）

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now()) @updatedAt
}

/// 外部認証プロバイダー（OAuth）のアカウント情報を管理するテーブル
/// 1人のユーザーが複数の認証方法（Google, 42, GitHubなど）を持てるように設計
model Accounts {
  id                Int      @id @default(autoincrement())

  statusId          Int          /// アカウント連携のステータス（Statusesテーブルへの参照）
  userId            Int          /// 紐付くユーザーのID (Users.id)
  
  provider          AuthProvider /// 認証プロバイダーの種類
  providerAccountId String       /// プロバイダー側でのユーザーID (sub, id等)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  /// 同じプロバイダーで同じアカウントIDが重複しないように制約を設定
  @@unique([provider, providerAccountId])
}

/// トーナメント情報を管理するテーブル
model Tournaments {
  id              Int               @id @default(autoincrement())
  
  statusId        Int               /// トーナメントの進行状況（Statusesテーブルへの参照）
  winnerId        Int?              /// 勝者のユーザーID（試合終了までNULL）

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
}

/// 待機室（マッチング待ち）テーブル
model WaitingRooms {
  id              Int                 @id @default(autoincrement())
  
  statusId        Int                 /// 待機室のステータス（Statusesテーブルへの参照）
  name            String              /// 部屋名
  adminUserId     Int                 /// 部屋の管理者（作成者）
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @default(now()) @updatedAt
}

/// 待機室の参加者管理テーブル
model WaitingRoomParticipants {
  id            Int      @id @default(autoincrement())

  statusId      Int      /// 参加者のステータス（Statusesテーブルへの参照）
  waitingRoomId Int      /// 参加している待機室ID
  userId        Int      /// 参加しているユーザーID
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  
  // 同じ部屋に同じユーザーが重複しないように
  @@unique([waitingRoomId, userId])
}

/// 試合情報を管理するテーブル（トーナメント内の1試合の記録）
model Games {
  id              Int               @id @default(autoincrement())
  
  statusId        Int               /// 試合の進行状況（Statusesテーブルへの参照）
  tournamentId    Int               /// 所属トーナメントID
  round           Int               @default(1) /// 何回戦か (1: 1回戦, 2: 2回戦...)
  order           Int               @default(1) /// そのラウンド内の何試合目か
  playerNum       Int               @default(2) /// 参加人数（基本は2）
  gameTypeId      Int
  winnerId        Int?              /// 勝者のユーザーID（試合終了までNULL）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
}

/// ゲームの種類（ルール設定など）を管理するテーブル
model GameTypes {
  id              Int               @id @default(autoincrement())
  
  statusId        Int               /// ゲーム種別のステータス（Statusesテーブルへの参照）
  gameType        String            /// ゲームの種類名（2人対戦, 4人対戦）
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
}

/// 試合ごとのプレイヤー成績を管理するテーブル
model PlayerScores {
  id              Int               @id @default(autoincrement())

  statusId        Int               /// スコアのステータス（Statusesテーブルへの参照）
  gameId          Int               /// 対象の試合ID
  userId          Int               /// プレイヤーのユーザーID
  score           Int               @default(0) /// 獲得スコア
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
}